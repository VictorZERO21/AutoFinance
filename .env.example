# Django Configuration
SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=autofinance-app.run.app,localhost,127.0.0.1

# Local PostgreSQL (preferred for local testing)
DATABASE_URL=postgresql://autofinance:autofinance@localhost:5432/autofinance

# Cloud SQL Configuration
USE_CLOUD_SQL=False
CLOUD_SQL_DATABASE=autofinance_db
CLOUD_SQL_USER=postgres
CLOUD_SQL_PASSWORD=your-postgres-password
CLOUD_SQL_HOST=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
CLOUD_SQL_PORT=5432

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:3000
